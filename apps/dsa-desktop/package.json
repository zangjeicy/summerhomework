{
    "name":  "daily-stock-analysis-desktop",
    "version":  "3.21.0",
    "private":  true,
    "main":  "main.js",
    "scripts":  {
                    "dev":  "electron .",
                    "build":  "electron-builder",
                    "test":  "node --test tests/*.test.js"
                },
    "dependencies":  {
                         "electron-updater":  "^6.8.3"
                     },
    "devDependencies":  {
                            "electron":  "^31.4.0",
                            "electron-builder":  "^24.13.3"
                        },
    "build":  {
                  "appId":  "com.ruyi.daily-stock-analysis",
                  "productName":  "金股睿析",
                  "directories":  {
                                      "output":  "dist"
                                  },
                  "files":  [
                                "main.js",
                                "preload.js",
                                "renderer/**/*"
                            ],
                  "extraResources":  [
                                         {
                                             "from":  "../../.env.example",
                                             "to":  ".env.example"
                                         },
                                         {
                                             "from":  "../../dist/backend/stock_analysis",
                                             "to":  "backend/stock_analysis"
                                         },
                                         {
                                             "from":  "../../product-release.json",
                                             "to":  "product-release.json"
                                         }
                                     ],
                  "win":  {
                              "target":  "nsis",
                              "artifactName":  "ruyi-daily-stock-analysis-windows-installer-v\\${version}.\\${ext}"
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true,
                               "allowElevation":  false,
                               "include":  "installer.nsh"
                           },
                  "mac":  {
                              "target":  "dmg"
                          }
              }
}
